[init]
	defaultBranch = main

[core]
	pager = delta
[interactive]
	diffFilter = delta --color-only
[delta]
	navigate = true  # use n and N to move between diff sections
	dark = true      # or light = true, or omit for auto-detection
[merge]
	conflictstyle = zdiff3

[gpg]
	format = ssh
[commit]
	gpgsign = true

[includeIf "gitdir:~/Code/aur/"]
	path = ~/Code/aur/.gitconfig
[includeIf "gitdir:~/Code/github/"]
  path = ~/Code/github/.gitconfig
[includeIf "gitdir:~/.dotfiles/"]
  path = ~/Code/github/.gitconfig
[includeIf "gitdir:~/.dotfiles-private/"]
  path = ~/Code/github/.gitconfig

[filter "antigravity-cli"]
  clean = jq --sort-keys 'with_entries(select(.key as $k | [\"colorScheme\", \"enableTelemetry\", \"hooks\"] | index($k)))'
  smudge = $HOME/.config/git/filters/smudge-merge.sh $HOME/.gemini/antigravity-cli/settings.json
[filter "antigravity-global"]
  clean = jq --sort-keys '{userSettings: {globalPermissionGrants: .userSettings.globalPermissionGrants}}'
  smudge = $HOME/.config/git/filters/smudge-merge.sh $HOME/.gemini/config/config.json
